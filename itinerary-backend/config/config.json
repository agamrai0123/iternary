{
  "server": {
    "port": "8080",
    "timeout": 30,
    "mode": "debug"
  },
  "database": {
    "host": "localhost",
    "port": "1521",
    "user": "system",
    "service": "XE",
    "database": "itinerary_db",
    "password": ""
  },
  "logging": {
    "level": "info",
    "format": "text",
    "output": "./log/itinerary.log"
  },
  "api": {
    "page_size": 10,
    "max_items_per_itinerary": 50,
    "cors": {
      "allowed_origins": [
        "http://localhost:3000",
        "http://localhost:8000"
      ],
      "allowed_methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "allowed_headers": [
        "Content-Type",
        "Authorization"
      ]
    }
  }
}
