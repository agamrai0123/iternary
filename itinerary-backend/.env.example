# Oracle Database Configuration
# These override settings in config/config.json
DB_HOST=localhost
DB_PASSWORD=your_oracle_system_password

# Note: Other database settings are in config/config.json:
# - DB_PORT: 1521 (Oracle default)
# - DB_USER: system (Oracle admin)
# - SERVICE: XE (Oracle Express Edition)

# Example Oracle Connection String (for reference):
# system/password@localhost:1521/XE

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Server Configuration
# SERVER_PORT is in config/config.json
# Default: :8080

# API Keys (for future integration)
# BOOKING_API_KEY=your_key
# MAKEMYTRIP_API_KEY=your_key
# GOOGLE_MAPS_API_KEY=your_key
